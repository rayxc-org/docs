        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/generate",
              "api-reference/endpoint/job-status",
              "api-reference/endpoint/job-deployed"
            ]
          }
        ]
      }
